{
  "name": "shain",
  "version": "0.1.0",
  "license": "MIT",
  "description": "階層型マルチエージェント基盤 — オーケストレーター(対話層) + ワーカー(作業層)",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "start:login": "SHAIN_AUTH=login tsx src/index.ts",
    "task": "SHAIN_AUTH=login tsx src/index.ts -p",
    "hire": "SHAIN_AUTH=login SHAIN_KICKOFF=\"AI社員を新しく雇いたいです。docs/prompts/hire-employee.md の採用フローに従って、専門用語を使わず、私に一つずつ質問するところから始めてください。\" tsx src/index.ts",
    "otsukai": "SHAIN_AUTH=login tsx src/otsukai.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.198",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
